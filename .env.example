PORT=3000
DATABASE_URL=postgres://xfleet:xfleet@localhost:5432/xfleet
ADMIN_USERNAME=admin
# bcrypt hash — must be double-quoted with \$ escaping so both docker compose and Bun
# preserve the literal $ characters (e.g. $2b$10$abc... → "\$2b\$10\$abc...")
ADMIN_PASSWORD_HASH=""
SESSION_SECRET=
MASTER_KEY=
PROFILE_TITLE=VPN
PUBLIC_BASE_URL=http://localhost:3000

# Set to true when running behind a reverse proxy (nginx, Caddy, Cloudflare, etc.)
# that sets X-Forwarded-For. When true, the first XFF entry is stored in the
# subscription fetch journal; when false (default), the direct socket peer is used.
TRUST_PROXY=false

# How many days of /sub/:token fetch history to retain. Must be >= 1.
# A daily purge removes rows older than this. Default is 90.
SUB_JOURNAL_RETENTION_DAYS=90

# Only for docker-compose.prod.yml (compose derives DATABASE_URL from this).
# Use alphanumeric/hex (e.g. `openssl rand -hex 32`) — URL-special chars break DATABASE_URL.
POSTGRES_PASSWORD=

# Only for tests
TEST_DATABASE_URL=postgres://xfleet:xfleet@localhost:5432/xfleet_test
